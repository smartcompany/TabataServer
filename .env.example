# Server environment (copy to .env.local)

# Admin dashboard login
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
DASHBOARD_SECRET=change-me-to-a-long-random-string

# Dashboard app origin for CORS (production dashboard URL)
DASHBOARD_ORIGIN=https://your-dashboard.vercel.app

# Required on Vercel for admin profile writes
# BLOB_READ_WRITE_TOKEN=
